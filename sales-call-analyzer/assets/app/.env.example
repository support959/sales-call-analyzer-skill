# ===== הגדרות מנתח השיחות =====
# העתיקו קובץ זה לשם .env (בלי ה-.example) ומלאו את המפתחות.
# הקובץ הזה נשאר במחשב שלכם בלבד ואסור להעלות אותו לאינטרנט/גיט.

# חובה — מפתח Anthropic לניתוח השיחה (console.anthropic.com ← API Keys)
ANTHROPIC_API_KEY=

# רק אם רוצים לנתח הקלטות אודיו — מפתח OpenAI לתמלול (platform.openai.com/api-keys)
# אם תדביקו תמליל כטקסט, אפשר להשאיר ריק.
OPENAI_API_KEY=

# ----- אפשרויות (אפשר להשאיר כברירת מחדל) -----

# מודל הניתוח. ברירת המחדל מאוזנת בין איכות לעלות.
# לניתוח מעמיק יותר (ויקר יותר) החליפו ל:  claude-opus-4-8
ANALYSIS_MODEL=claude-sonnet-4-6
ANALYSIS_MAX_TOKENS=4096

# מודל ושפת התמלול
TRANSCRIBE_MODEL=whisper-1
TRANSCRIBE_LANGUAGE=he

# מיתוג הדף (שם וצבע ראשי)
BRAND_NAME=מנתח שיחות מכירה
BRAND_COLOR=#b8902e

# הכתובת המקומית שבה הדף ייפתח
PORT=4848
